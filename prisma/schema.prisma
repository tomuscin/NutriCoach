// NutriCoach — Prisma Schema v3
// ETAP 6: Daily Experience + Productization
// Database: MySQL / MariaDB (WEBD.pl — tomuscin_nutricoach)
// ORM: Prisma v5
//
// SHARED-HOSTING MYSQL COMPATIBILITY NOTES:
//   1. NAMING STRATEGY: All physical table names use plural snake_case via @@map().
//      TypeScript/Prisma model names remain PascalCase (unchanged domain API).
//      Rationale: shared-hosting MySQL has system tables in the `mysql` schema
//      (e.g. mysql.user, mysql.session) and some hosts add ACL rules that
//      block access to tables whose names shadow system/reserved identifiers.
//      Plural snake_case (users, sessions, accounts) avoids all known conflicts.
//   2. No connection pooling URL needed (no Neon directUrl).
//   3. JSON fields: MySQL 5.7.8+ = native JSON, MariaDB 10.2+ = LONGTEXT (Prisma handles transparently).
//   4. Descending index hints (sort: Desc) removed — not supported on MariaDB.
//   5. No shadow DB: use `prisma db push` instead of `prisma migrate dev` (WEBD.pl lacks CREATE DATABASE privilege).

generator client {
  provider      = "prisma-client-js"
  // Binary targets for Vercel serverless (Amazon Linux 2023 = rhel-openssl-3.0.x).
  // linux-musl-openssl-3.0.x covers Alpine-based runtimes.
  // native = local macOS/Linux development.
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  // relationMode = "prisma"  // uncomment if using PlanetScale or foreign keys are disabled
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════════

enum Gender {
  MALE
  FEMALE
}

enum UserRole {
  USER
  ADMIN
  TESTER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum UnitSystem {
  METRIC
  IMPERIAL
}

enum GoalType {
  REDUCTION    // caloric deficit, lose weight
  MAINTENANCE  // maintain weight, optimize performance
  GAIN         // caloric surplus, gain mass
  PERFORMANCE  // performance-focused, weight secondary
}

enum GoalPriority {
  PERFORMANCE     // minimize performance impact
  BALANCED        // balance performance and reduction
  AGGRESSIVE_CUT  // prioritize rapid reduction
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
  ARCHIVED
}

enum ActivityLevel {
  SEDENTARY    // desk job, no exercise
  LIGHT        // 1-3 days/week
  MODERATE     // 3-5 days/week
  VERY_ACTIVE  // 6-7 days/week
  EXTRA_ACTIVE // 2x/day training or very physical job
}

enum SportType {
  CYCLING
  RUNNING
  SWIMMING
  TRIATHLON
  DUATHLON
  STRENGTH
  MTB
  GRAVEL
  ROWING
  SKIING
  HIKING
  YOGA
  CROSSFIT
  WALK
  ELLIPTICAL
  PILATES
  OTHER
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  PRE_WORKOUT
  POST_WORKOUT
  SUPPLEMENT
}

enum MealSource {
  MANUAL
  AI_EXTRACTED
  OCR
  PHOTO_ANALYSIS
  EXCEL_IMPORT
}

enum MetricSource {
  MANUAL
  GARMIN
  TRAININGPEAKS
  SMART_SCALE
  EXCEL_IMPORT
  CALCULATED
}

enum RecoveryStatus {
  PEAK      // readiness >= 85
  HIGH      // readiness >= 70
  MODERATE  // readiness >= 50
  LOW       // readiness >= 30
  VERY_LOW  // readiness < 30
}

enum WorkoutSource {
  MANUAL
  TRAININGPEAKS
  GARMIN
  STRAVA
  EXCEL_IMPORT
}

enum InsightType {
  MORNING_BRIEF
  MIDDAY_CHECK
  EVENING_REVIEW
  GOAL_UPDATE
  RECOVERY_ALERT
  NUTRITION_ALERT
  PERFORMANCE_UPDATE
  WEEKLY_SUMMARY
  MILESTONE
}

enum InsightDeliveryMoment {
  MORNING
  MIDDAY
  EVENING
  ON_DEMAND
  TRIGGERED
}

enum InsightFeedback {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

enum IntegrationProvider {
  TRAININGPEAKS
  GARMIN
  STRAVA
  MANUAL
}

enum IntegrationStatus {
  ACTIVE
  EXPIRED
  DISCONNECTED
  ERROR
  PENDING
  REVOKED
}

enum SyncType {
  WORKOUTS
  BODY_METRICS
  SLEEP
  RECOVERY
  ATHLETE_PROFILE
  FULL
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
  SKIPPED
  CANCELLED
}

enum NotificationType {
  MORNING_BRIEF
  MIDDAY_CHECK
  EVENING_REVIEW
  GOAL_MILESTONE
  NUTRITION_REMINDER
  SYNC_COMPLETE
  SYNC_ERROR
  WEEKLY_REPORT
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL_SUCCESS
  FAILED
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUTH MODELS (NextAuth / Auth.js v5)
// ═══════════════════════════════════════════════════════════════════════════════

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?  // GDPR soft delete

  // ETAP 7 — onboarding state
  onboardingStep Int @default(0) // 0=not started, 1-7 in progress, 8=complete

  // Auth.js
  accounts Account[]
  sessions Session[]

  // NutriCoach domain
  profile             UserProfile?
  goals               Goal[]
  goalHistory         GoalHistory[]
  dailyLogs           DailyLog[]
  meals               Meal[]
  bodyMetrics         BodyMetric[]
  workouts            Workout[]
  sleepMetrics        SleepMetric[]
  recoveryMetrics     RecoveryMetric[]
  trainingLoads       TrainingLoad[]
  aiInsights          AIInsight[]
  aiPreferences       AIUserPreferences?
  notifications       Notification[]
  integrations        Integration[]
  syncLogs            SyncLog[]
  excelImportSessions ExcelImportSession[]
  // ETAP 6
  dailyReadiness      DailyReadiness[]
  adherenceRecords    AdherenceRecord[]
  dailyScores         DailyScore[]
  aiScheduleConfig    AIScheduleConfig?
  aiRollingSummaries  AIRollingSummary[]
  // ETAP 7
  consents          UserConsent[]
  preferences       UserPreferences?
  pushSubscriptions PushSubscription[]
  analyticsEvents   AnalyticsEvent[]

  @@index([email])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════════════════════════════
// USER PROFILE
// ═══════════════════════════════════════════════════════════════════════════════

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique

  // Identity
  sex       Gender
  birthDate DateTime
  heightCm  Float

  // Current state
  currentWeightKg Float
  targetWeightKg  Float?

  // Activity & Sport
  activityLevel ActivityLevel @default(MODERATE)
  mainSport     SportType     @default(CYCLING)
  unitSystem    UnitSystem    @default(METRIC)
  timezone      String        @default("Europe/Warsaw")

  // Training parameters (performance athletes)
  ftp      Float? // Functional Threshold Power (watts)
  ftpPerKg Float? // Computed: ftp / currentWeightKg
  lthr     Float? // Lactate Threshold HR
  vo2max   Float? // VO2 max (ml/kg/min)
  restingHR Int?  // beats per minute

  // Metabolic targets (calculated by nutrition-engine)
  bmr           Float?
  tdee          Float?
  caloricTarget Float?
  proteinTargetG Float?
  carbsTargetG   Float?
  fatTargetG     Float?

  // Goal preferences
  preferredReductionMode String @default("moderate") // moderate|aggressive|very_aggressive

  // HRV baseline (rolling 30-day)
  hrvBaseline      Float?
  hrvLastUpdatedAt DateTime?

  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ═══════════════════════════════════════════════════════════════════════════════
// GOALS & GOAL HISTORY
// ═══════════════════════════════════════════════════════════════════════════════

model Goal {
  id       String       @id @default(cuid())
  userId   String
  type     GoalType
  priority GoalPriority @default(BALANCED)
  status   GoalStatus   @default(ACTIVE)

  // Weight targets
  startWeightKg  Float
  targetWeightKg Float

  // Performance targets
  startFTP       Float? // watts at goal start
  targetFTP      Float?
  targetFTPperKg Float?

  // Reduction parameters
  weeklyWeightChangeKg Float  @default(-0.5) // negative = loss
  targetCaloricDeficit Float? // kcal/day

  // Timeline
  startDate  DateTime  @db.Date
  targetDate DateTime? @db.Date
  achievedAt DateTime?
  archivedAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  history GoalHistory[]

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("goals")
}

// Immutable audit trail — every goal state change creates a row here
model GoalHistory {
  id             String     @id @default(cuid())
  goalId         String
  userId         String
  previousStatus GoalStatus
  newStatus      GoalStatus
  reason         String?
  triggeredBy    String?    // 'user' | 'system' | 'auto'
  snapshot       Json       // full goal state at time of change
  changedAt      DateTime   @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([goalId, changedAt])
  @@index([userId, changedAt])
  @@map("goal_history")
}

// ═══════════════════════════════════════════════════════════════════════════════
// NUTRITION LOGS
// ═══════════════════════════════════════════════════════════════════════════════

model DailyLog {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date

  // Targets (snapshot from profile at log creation)
  targetCalories Float
  targetProteinG Float
  targetCarbsG   Float?
  targetFatG     Float?

  // Consumed totals (denormalized — recalculated on each Meal upsert)
  consumedCalories Float   @default(0)
  consumedProteinG Float   @default(0)
  consumedCarbsG   Float   @default(0)
  consumedFatG     Float   @default(0)
  consumedFiberG   Float?
  consumedSodiumMg Float?
  consumedSugarG   Float?

  // Daily energy balance
  tdeeSnapshot   Float? // TDEE at day end (includes workout calories)
  calorieBalance Float? // consumedCalories - tdeeSnapshot
  deficit        Float? // positive = deficit, negative = surplus

  // Hydration
  waterMl Int?

  // State
  completedAt DateTime?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals      Meal[]
  aiInsights AIInsight[]

  @@unique([userId, date])
  @@index([userId, date])
  @@index([userId, consumedCalories])
  @@index([userId, completedAt])
  @@map("daily_logs")
}

model Meal {
  id         String     @id @default(cuid())
  dailyLogId String
  userId     String     // denormalized for direct user queries
  mealType   MealType
  source     MealSource @default(MANUAL)

  name String?
  time String? // HH:MM local time

  // Macros
  calories Float
  proteinG Float
  carbsG   Float
  fatG     Float
  fiberG   Float?
  sodiumMg Float?
  sugarG   Float?

  // Import tracking
  importSessionId String?

  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@index([userId, mealType])
  @@index([userId, deletedAt])
  @@index([importSessionId])
  @@map("meals")
}

// ═══════════════════════════════════════════════════════════════════════════════
// BODY METRICS (immutable time series — append only)
// ═══════════════════════════════════════════════════════════════════════════════

model BodyMetric {
  id         String       @id @default(cuid())
  userId     String
  date       DateTime     @db.Date
  recordedAt DateTime     @default(now())
  source     MetricSource @default(MANUAL)
  externalId String?      // Garmin/TP ID for deduplication

  // Measurements
  weightKg         Float?
  bodyFatPercent   Float?
  muscleMassKg     Float?
  bmi              Float?  // computed: weight / (height/100)^2
  waistCm          Float?
  hipCm            Float?
  hydrationPercent Float?

  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, recordedAt])
  @@index([userId, source])
  @@map("body_metrics")
}

// ═══════════════════════════════════════════════════════════════════════════════
// SLEEP METRICS (immutable time series)
// ═══════════════════════════════════════════════════════════════════════════════

model SleepMetric {
  id         String       @id @default(cuid())
  userId     String
  date       DateTime     @db.Date // night of sleep (start date)
  source     MetricSource @default(MANUAL)
  externalId String?

  sleepStart DateTime
  sleepEnd   DateTime

  // Minutes breakdown
  totalSleepMinutes Int?
  deepSleepMinutes  Int?
  remSleepMinutes   Int?
  lightSleepMinutes Int?
  awakeMinutes      Int?

  // Quality scores
  sleepScore      Int?   // 0-100 composite
  restfulness     Float? // 0-1
  sleepEfficiency Float? // totalSleep / timeInBed

  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, source])
  @@map("sleep_metrics")
}

// ═══════════════════════════════════════════════════════════════════════════════
// RECOVERY METRICS (immutable time series)
// ═══════════════════════════════════════════════════════════════════════════════

model RecoveryMetric {
  id         String         @id @default(cuid())
  userId     String
  date       DateTime       @db.Date
  recordedAt DateTime       @default(now())
  source     MetricSource   @default(MANUAL)
  externalId String?

  // HRV & HR
  hrv      Float? // Heart Rate Variability ms (RMSSD)
  restingHR Int?  // bpm

  // Composite scores (0-100)
  readinessScore Int?   // primary recovery indicator
  fatigueScore   Int?   // higher = more fatigued
  stressScore    Int?   // higher = more stressed
  recoveryScore  Int?   // overall recovery quality

  status RecoveryStatus?

  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, recordedAt])
  @@index([userId, status])
  @@map("recovery_metrics")
}

// ═══════════════════════════════════════════════════════════════════════════════
// WORKOUTS
// ═══════════════════════════════════════════════════════════════════════════════

model Workout {
  id     String        @id @default(cuid())
  userId String
  date   DateTime      @db.Date
  source WorkoutSource @default(MANUAL)

  // External tracking (for deduplication)
  externalId          String?
  externalWorkoutType String? // raw sport type from external source

  // Timing
  startedAt       DateTime?
  finishedAt      DateTime?
  durationMinutes Float

  // Activity
  title         String?
  description   String?
  sportType     SportType @default(OTHER)
  distanceKm    Float?
  elevationGainM Float?
  indoor        Boolean   @default(false)

  // Heart rate
  avgHR Int?
  maxHR Int?

  // Power (cycling/rowing)
  avgPowerW        Float?
  normalizedPowerW Float?
  maxPowerW        Float?
  avgCadence       Float?

  // Energy
  caloriesBurned Float?

  // Training load
  tss             Float? // Training Stress Score
  intensityFactor Float? // IF = NP / FTP
  ftpSnapshot     Float? // FTP at time of workout (historical context)

  // Subjective
  rpe               Int? // Rate of Perceived Exertion 1-10
  perceivedExertion Int? // 1-5 scale

  // Planning (if synced from TP as planned workout)
  isPlanned          Boolean @default(false)
  plannedDurationMin Float?
  plannedTSS         Float?

  // Environment
  weatherCondition String?
  temperatureC     Float?

  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId, source], name: "workout_deduplication")
  @@index([userId, date])
  @@index([userId, sportType])
  @@index([userId, source])
  @@index([userId, tss])
  @@index([userId, deletedAt])
  @@index([externalId])
  @@map("workouts")
}

// ═══════════════════════════════════════════════════════════════════════════════
// TRAINING LOAD — Daily PMC snapshots (CTL/ATL/TSB)
// ═══════════════════════════════════════════════════════════════════════════════

model TrainingLoad {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date

  // Performance Management Chart
  ctl Float // Chronic Training Load (fitness)  — 42-day EWA
  atl Float // Acute Training Load  (fatigue)  — 7-day EWA
  tsb Float // Training Stress Balance (form)   = CTL - ATL

  // Daily TSS that drove this snapshot
  dailyTSS Float @default(0)

  computedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@index([userId, tsb])
  @@map("training_loads")
}

// ═══════════════════════════════════════════════════════════════════════════════
// AI INSIGHTS
// ═══════════════════════════════════════════════════════════════════════════════

model AIInsight {
  id         String                @id @default(cuid())
  userId     String
  dailyLogId String?

  // Classification
  insightType    InsightType
  deliveryMoment InsightDeliveryMoment

  // AI provenance
  promptVersion    String
  model            String // gpt-4o | gpt-4o-mini
  promptTokens     Int
  completionTokens Int
  totalTokens      Int

  // Context fed to AI (for debugging & prompt improvement)
  contextSnapshot Json

  // Output
  content        String  @db.Text // full generated insight
  recommendation String? @db.Text // actionable recommendation

  // Quality — multi-dimensional (ETAP 5.5)
  confidenceScore          Float? // 0-1, overall
  nutritionConfidence      Float? // 0-1, nutrition dimension
  trainingConfidence       Float? // 0-1, training dimension
  recoveryConfidence       Float? // 0-1, recovery dimension
  dataCompleteness         Float? // 0-1, how complete context was
  dataFreshness            Float? // 0-1, how fresh the data was
  missingSignals           Json?  // string[], signals that were absent

  // Explainability (ETAP 5.5)
  primaryDrivers    Json? // string[], main factors driving recommendation
  supportingSignals Json? // string[], supporting data points
  explanationWarnings Json? // string[], important warnings for user

  // User interaction
  acknowledgedAt DateTime?
  feedback       InsightFeedback?
  feedbackNote   String?
  feedbackAt     DateTime?

  // Lifecycle (ETAP 6)
  status        InsightStatus @default(GENERATED)
  deliveredAt   DateTime?
  viewedAt      DateTime?
  interactedAt  DateTime?
  archivedAt    DateTime?

  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyLog DailyLog? @relation(fields: [dailyLogId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, insightType, deliveryMoment])
  @@index([userId, acknowledgedAt])
  @@index([userId, feedback])
  @@index([dailyLogId])
  @@map("ai_insights")
}

// ═══════════════════════════════════════════════════════════════════════════════
// AI USER PREFERENCES (ETAP 5.5)
// ═══════════════════════════════════════════════════════════════════════════════

model AIUserPreferences {
  id     String @id @default(cuid())
  userId String @unique

  // Coaching personality
  coachingTone        CoachingTone       @default(BALANCED)
  verbosity           AIVerbosity        @default(STANDARD)
  riskTolerance       AIRiskTolerance    @default(MODERATE)
  recommendationStyle RecommendationStyle @default(DIRECTIVE)

  // Focus priorities
  preferredFocus   AIFocusArea @default(NUTRITION)
  motivationStyle  String?     // free-form, e.g. "data-driven, no fluff"

  // Display preferences
  showConfidenceBar    Boolean @default(true)
  showExplanations     Boolean @default(true)
  showWarnings         Boolean @default(true)
  lowConfidenceWarning Boolean @default(true)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_user_preferences")
}

enum CoachingTone {
  STRICT       // direct, no-nonsense
  BALANCED     // professional + warm
  ENCOURAGING  // motivational, positive
}

enum AIVerbosity {
  BRIEF    // max 1 sentence per section
  STANDARD // normal
  DETAILED // full context + rationale
}

enum AIRiskTolerance {
  CONSERVATIVE // stay within very safe ranges
  MODERATE     // standard evidence-based
  AGGRESSIVE   // performance-optimized
}

enum RecommendationStyle {
  DIRECTIVE   // tell me what to do
  EDUCATIONAL // explain why
  EXPLORATORY // give options
}

enum AIFocusArea {
  NUTRITION
  RECOVERY
  PERFORMANCE
  WEIGHT
  BALANCED
}

// ═══════════════════════════════════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════════════════════════════════

model Notification {
  id      String             @id @default(cuid())
  userId  String
  type    NotificationType
  status  NotificationStatus @default(PENDING)
  channel NotificationChannel @default(IN_APP)

  title String
  body  String @db.Text
  data  Json?  // extra context (link, insightId, etc.) — stored as JSON (MySQL 5.7.8+) or LONGTEXT (MariaDB)

  scheduledFor DateTime?
  sentAt       DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  errorMessage String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([userId, scheduledFor])
  @@index([userId, readAt])
  @@map("notifications")
}

// ═══════════════════════════════════════════════════════════════════════════════
// INTEGRATIONS (generic — supports TP, Garmin, future providers)
// ═══════════════════════════════════════════════════════════════════════════════

model Integration {
  id       String              @id @default(cuid())
  userId   String
  provider IntegrationProvider
  status   IntegrationStatus   @default(PENDING)

  // OAuth tokens (stored AES-256-GCM encrypted)
  accessToken    String?  @db.Text
  refreshToken   String?  @db.Text
  tokenExpiresAt DateTime?

  // Scopes granted
  scope String?

  // External athlete ID
  athleteExternalId String?

  // Sync configuration
  syncFrequencyMinutes Int      @default(360) // 6 hours
  lastSyncAt           DateTime?
  nextSyncAt           DateTime?

  // Permissions granted (which data types to sync)
  permissions Json? // { workouts: true, sleep: false, recovery: true }

  // Error tracking
  errorMessage String?
  errorCount   Int       @default(0)
  lastErrorAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncLogs SyncLog[]

  @@unique([userId, provider])
  @@index([userId, status])
  @@index([userId, provider])
  @@index([nextSyncAt]) // sync scheduler queries
  @@map("integrations")
}

model SyncLog {
  id            String     @id @default(cuid())
  integrationId String
  userId        String
  syncType      SyncType
  status        SyncStatus @default(PENDING)

  // Results
  recordsProcessed Int @default(0)
  recordsCreated   Int @default(0)
  recordsUpdated   Int @default(0)
  recordsSkipped   Int @default(0)
  recordsFailed    Int @default(0)

  // Timing
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  // Error details
  errors Json? // array of { record, message } objects

  // Retry tracking
  retryCount  Int       @default(0)
  lastRetryAt DateTime?
  nextRetryAt DateTime?

  createdAt DateTime @default(now())

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([integrationId, startedAt])
  @@index([userId, status])
  @@index([userId, startedAt])
  @@map("sync_logs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXCEL IMPORT
// ═══════════════════════════════════════════════════════════════════════════════

model ExcelImportSession {
  id     String       @id @default(cuid())
  userId String
  status ImportStatus @default(PENDING)

  // File identification
  fileName String
  fileHash String // SHA-256 for deduplication

  // Column mapping used (user may override defaults)
  columnMapping Json

  // Statistics
  rowsTotal    Int @default(0)
  rowsParsed   Int @default(0)
  rowsImported Int @default(0)
  rowsSkipped  Int @default(0)
  rowsFailed   Int @default(0)

  // Date range of imported data
  importedDateRangeStart DateTime? @db.Date
  importedDateRangeEnd   DateTime? @db.Date

  // Timing
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  // Top-level error (if session failed entirely)
  errorMessage String?

  createdAt DateTime @default(now())

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  errors ExcelImportError[]

  @@unique([userId, fileHash])
  @@index([userId, createdAt])
  @@index([userId, status])
  @@map("excel_import_sessions")
}

model ExcelImportError {
  id         String @id @default(cuid())
  sessionId  String
  rowNumber  Int
  columnName String?
  rawValue   String?
  errorType  String // missing_required | invalid_format | out_of_range | parse_error
  errorMessage String

  createdAt DateTime @default(now())

  session ExcelImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("excel_import_errors")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ETAP 6: INSIGHT LIFECYCLE
// ═══════════════════════════════════════════════════════════════════════════════

enum InsightStatus {
  GENERATED   // created by AI engine
  DELIVERED   // sent to user (notification triggered)
  VIEWED      // user opened/read the insight
  INTERACTED  // user took an action (feedback, click, etc.)
  ARCHIVED    // no longer shown in active feed
}

// ═══════════════════════════════════════════════════════════════════════════════
// ETAP 6: DAILY READINESS
// ═══════════════════════════════════════════════════════════════════════════════

model DailyReadiness {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date

  // Composite readiness score
  score      Float  // 0-100
  level      String // 'low' | 'moderate' | 'high'
  confidence Float  // 0-1

  // Input signals (snapshot)
  hrv               Float?
  restingHR         Int?
  sleepScore        Int?
  sleepMinutes      Int?
  atl               Float?  // Acute Training Load
  ctl               Float?
  tsb               Float?  // Training Stress Balance
  calorieBalance7d  Float?  // avg 7d deficit/surplus
  weightTrend7d     Float?  // delta kg/7d
  adherenceScore7d  Float?  // 0-1, how well they followed recommendations

  // Outputs
  recommendedTrainingLoad Float   // recommended TSS for today
  recommendedFocus        Json    // string[], e.g. ["recovery", "hydration"]
  drivers                 Json    // string[], top factors
  warnings                Json    // string[], notable flags

  computedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_readiness")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ETAP 6: ADHERENCE TRACKING
// ═══════════════════════════════════════════════════════════════════════════════

model AdherenceRecord {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date

  // Nutrition adherence
  kcalTarget       Float?
  kcalActual       Float?
  kcalAdherence    Float?  // 0-1
  proteinTarget    Float?
  proteinActual    Float?
  proteinAdherence Float?  // 0-1

  // Training adherence
  tssTarget       Float?
  tssActual       Float?
  workoutCompleted Boolean @default(false)
  plannedWorkouts  Int     @default(0)
  completedWorkouts Int    @default(0)

  // Overall
  dailyAdherenceScore Float?  // 0-1, weighted composite
  streakDays          Int     @default(0)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("adherence_records")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ETAP 6: DAILY SCORES
// ═══════════════════════════════════════════════════════════════════════════════

model DailyScore {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date

  // Dimension scores (0-100)
  performanceScore  Int?  // training execution vs plan
  recoveryScore     Int?  // sleep + HRV + readiness
  consistencyScore  Int?  // adherence streak quality
  nutritionScore    Int?  // macro compliance quality

  // Composite
  overallScore Int?

  // Explainability
  performanceDrivers  Json?  // string[]
  recoveryDrivers     Json?  // string[]
  consistencyDrivers  Json?  // string[]
  nutritionDrivers    Json?  // string[]

  scoreVersion String @default("1.0")
  computedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_scores")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ETAP 6: AI SCHEDULE CONFIG (per-user preferred generation times)
// ═══════════════════════════════════════════════════════════════════════════════

model AIScheduleConfig {
  id     String @id @default(cuid())
  userId String @unique

  morningHour   Int @default(6)   // 0-23
  morningMinute Int @default(30)  // 0-59
  middayHour    Int @default(12)
  middayMinute  Int @default(0)
  eveningHour   Int @default(21)
  eveningMinute Int @default(0)

  morningEnabled Boolean @default(true)
  middayEnabled  Boolean @default(true)
  eveningEnabled Boolean @default(true)

  timezone String @default("Europe/Warsaw")

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_schedule_configs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ETAP 6: AI ROLLING SUMMARY (daily memory — last 7 days compressed context)
// ═══════════════════════════════════════════════════════════════════════════════

model AIRollingSummary {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date  // summary covers rolling 7d ending this date

  // Compressed context (token-efficient summary of last N days)
  summaryText String @db.Text  // 200-400 token condensed narrative
  keyThemes   Json             // string[], recurring patterns
  openLoops   Json             // string[], unresolved topics from previous insights
  trendSignals Json            // { metric: string, direction: string, magnitude: string }[]
  weekScore   Int?             // 0-100 composite week quality

  tokenCount Int?

  summaryVersion String @default("1.0")
  generatedAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("ai_rolling_summaries")
}

// ═══════════════════════════════════════════════════════════════════════════════
// OAUTH STATE — CSRF protection for OAuth flows
// ═══════════════════════════════════════════════════════════════════════════════

model OAuthState {
  id        String              @id @default(cuid())
  userId    String
  state     String              @unique // random CSRF token
  provider  IntegrationProvider
  expiresAt DateTime            // 10 min TTL
  createdAt DateTime            @default(now())

  @@index([state])
  @@index([userId])
  @@index([expiresAt])
  @@map("oauth_states")
}

// ═══════════════════════════════════════════════════════════════════════════════
// WEBHOOK EVENTS — inbound webhooks from providers
// ═══════════════════════════════════════════════════════════════════════════════

model WebhookEvent {
  id               String              @id @default(cuid())
  provider         IntegrationProvider
  eventType        String              // e.g. 'workout_created', 'workout_updated'
  athleteExternalId String?            // provider athlete ID
  payload          Json
  signature        String?             // raw signature header for audit
  payloadHash      String?             // SHA-256 for deduplication

  status       String   @default("pending") // pending | processed | failed | duplicate
  processedAt  DateTime?
  errorMessage String?
  retryCount   Int      @default(0)

  createdAt DateTime @default(now())

  @@index([provider, status])
  @@index([athleteExternalId])
  @@index([payloadHash])
  @@index([createdAt])
  @@map("webhook_events")
}

// ══════════════════════════════════════════════════════════════════════════════
// EVENT JOURNAL — ETAP 6.75
// Full audit log of every significant runtime event.
// Enables replay, debugging, and observability.
// ══════════════════════════════════════════════════════════════════════════════

model EventJournal {
  id              String  @id @default(cuid())
  eventType       String  // e.g. 'sync.started', 'token.refreshed', 'insight.generated'
  source          String  // e.g. 'cron.sync-workouts', 'webhook.trainingpeaks', 'api.manual-sync'
  userId          String?
  correlationId   String? // x-request-id / trace correlation
  parentEventId   String? // for event chains
  payloadHash     String? // SHA-256 of payload for dedup
  payload         Json?   // event data (sanitized — no tokens)

  status           String   @default("ok") // ok | failed | retried | replayed
  processingMs     Int?     // wall-clock duration
  retryCount       Int      @default(0)
  errorMessage     String?  @db.Text
  errorStack       String?  @db.Text

  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([eventType])
  @@index([userId])
  @@index([correlationId])
  @@index([source])
  @@index([createdAt])
  @@map("event_journal")
}

// ══════════════════════════════════════════════════════════════════════════════
// RUNTIME METRICS — ETAP 6.75
// Rolling counters for operational dashboards. Reset daily.
// ══════════════════════════════════════════════════════════════════════════════

model RuntimeMetric {
  id        String   @id @default(cuid())
  name      String   // e.g. 'sync.success', 'ai.malformed', 'webhook.duplicate'
  value     Float    @default(0)
  labels    Json?    // { provider, operation, userId? }
  date      DateTime // UTC date (day granularity for rolling 7-day)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, date], name: "metric_name_date")
  @@index([name])
  @@index([date])
  @@map("runtime_metrics")
}

// ══════════════════════════════════════════════════════════════════════════════
// ETAP 7 — REAL USER SYSTEM
// ══════════════════════════════════════════════════════════════════════════════

// ─── USER CONSENT — GDPR / terms versioning ──────────────────────────────────

model UserConsent {
  id            String   @id @default(cuid())
  userId        String
  policyType    String   // "terms" | "privacy" | "health_disclaimer" | "data_processing"
  policyVersion String   // semver e.g. "1.0"
  acceptedAt    DateTime @default(now())
  ip            String?
  userAgent     String?  @db.Text
  revokedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, policyType])
  @@index([userId, acceptedAt])
  @@map("user_consents")
}

// ─── USER PREFERENCES — settings, AI prefs, notification prefs ──────────────

model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique

  // Notification channels
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(false)
  insightSchedule    String  @default("auto") // auto | morning | evening | all

  // AI preferences
  aiCoachingTone       String @default("balanced")     // motivating | balanced | data_driven | gentle
  aiVerbosity          String @default("normal")       // concise | normal | detailed
  aiRecoverySensitivity String @default("moderate")   // sensitive | moderate | aggressive
  aiInsightTiming      String @default("auto")         // auto | morning | midday | evening

  // Display preferences
  unitSystem   String @default("metric") // metric | imperial
  language     String @default("pl")
  timezone     String @default("Europe/Warsaw")
  darkMode     String @default("system") // system | dark | light

  // Privacy
  analyticsEnabled Boolean @default(true)
  crashReporting   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─── PUSH SUBSCRIPTIONS — Web Push API ───────────────────────────────────────

model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  endpoint String @db.Text
  p256dh   String @db.Text // public key
  auth     String @db.Text // auth secret

  deviceLabel String? // "iPhone Safari", "Chrome Desktop"
  isActive    Boolean @default(true)

  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("push_subscriptions")
}

// ─── ANALYTICS EVENTS — product funnel & retention ──────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  event     String   // "onboarding.started", "tp.connected", "insight.viewed"…
  properties Json?
  page      String?
  userAgent String?  @db.Text
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([userId, event])
  @@index([createdAt])
  @@map("analytics_events")
}
