# =============================================================================
# NUTRICOACH — ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env.local (apps/web) and fill in your values.
# NEVER commit real secrets to git.
# =============================================================================

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NutriCoach
NODE_ENV=development

# -----------------------------------------------------------------------------
# DATABASE — MySQL / MariaDB (WEBD.pl)
# Database name: tomuscin_nutricoach
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl=true&sslaccept=strict
# External access: enabled via WEBD.pl panel (remote MySQL access)
# SSL: required for remote connections
# -----------------------------------------------------------------------------
DATABASE_URL="mysql://tomuscin_nutricoach:password@YOUR_HOST.webd.pl:3306/tomuscin_nutricoach?ssl=true&sslaccept=strict"

# Local development (e.g. MAMP / Docker MySQL):
# DATABASE_URL="mysql://root:root@localhost:3306/nutricoach_dev"

# NOTE: No DIRECT_URL needed — that was PostgreSQL/Neon connection pooler specific.

# -----------------------------------------------------------------------------
# AUTH — NextAuth / Auth.js
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=your_secret_here_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OPENAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini

# -----------------------------------------------------------------------------
# TRAININGPEAKS INTEGRATION (OAuth 2.0)
# -----------------------------------------------------------------------------
TRAININGPEAKS_CLIENT_ID=
TRAININGPEAKS_CLIENT_SECRET=
TRAININGPEAKS_REDIRECT_URI=http://localhost:3000/api/integrations/trainingpeaks/callback
TRAININGPEAKS_SCOPE=workouts:read,athlete:read

# -----------------------------------------------------------------------------
# GARMIN INTEGRATION (future)
# -----------------------------------------------------------------------------
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
GARMIN_REDIRECT_URI=http://localhost:3000/api/integrations/garmin/callback

# -----------------------------------------------------------------------------
# EMAIL (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@nutricoach.app

# -----------------------------------------------------------------------------
# VERCEL / DEPLOYMENT
# -----------------------------------------------------------------------------
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# -----------------------------------------------------------------------------
# REDIS — BullMQ + Caching (REQUIRED from ETAP 3)
# Provides: AI context cache, job queues (AI briefs, TP sync, notifications),
# sync retry state, rate limiting, notification queues.
# WEBD.pl does not provide Redis — use Upstash (free tier) or Railway.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# Production (Upstash): rediss://default:TOKEN@HOST.upstash.io:6379
