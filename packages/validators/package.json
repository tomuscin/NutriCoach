{
  "name": "@nutricoach/validators",
  "version": "0.1.0",
  "private": true,
  "description": "Zod schemas, DTOs, and validators shared across apps",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
