{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",

  "installCommand": "cd ../.. && npm install",
  "buildCommand": "cd ../.. && npx prisma generate --schema=./prisma/schema.prisma && npm run build --workspace=apps/web",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",

  "regions": ["fra1"],

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],

  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 60
    }
  },

  "crons": [
    {
      "path": "/api/cron/morning-insights",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/midday-insights",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/evening-insights",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/daily-scores",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/sync-tokens",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sync-workouts",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/stale-scan",
      "schedule": "0 2 * * *"
    }
  ]
}

