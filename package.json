{
  "name": "leaxaro",
  "version": "0.1.0",
  "private": true,
  "description": "Leaxaro — AI-native Conversational Intelligence Platform for health, nutrition and performance",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "npx prisma studio",
    "db:seed": "turbo run db:seed",
    "infra:validate": "node scripts/validate-infra.mjs",
    "infra:migrate": "node -e \"require('dotenv').config({path:'apps/web/.env.local'})\" && npx prisma db push",
    "context:build": "npm run context:build --workspace=@leaxaro/pmos",
    "sync:pmos-runtime": "npm run sync:pmos-runtime --workspace=@leaxaro/pmos",
    "sync:pmos-conversations": "npm run sync:pmos-conversations --workspace=@leaxaro/pmos",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky",
    "postinstall": "prisma generate --schema=prisma/schema.prisma"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.0.0"
}
